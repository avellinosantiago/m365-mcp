# M365 Planner MCP Configuration
# Copy this file to .env and fill in your values

# =============================================================================
# Required Configuration
# =============================================================================

# Your default Planner Plan ID
# Find it in Planner URL: https://tasks.office.com/.../{PLAN_ID}/...
# Or use the Graph API: GET /me/planner/plans
PLANNER_DEFAULT_PLAN_ID=your-plan-id-here

# =============================================================================
# Optional Configuration
# =============================================================================

# HTTP timeout in seconds for Graph API requests (default: 30)
# GRAPH_TIMEOUT=30
